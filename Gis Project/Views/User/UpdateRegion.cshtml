@using Microsoft.AspNetCore.Identity


 @model UserRegionVM 

@{
    ViewData["Title"] = "تعديل عنصر";
}
<main>
    <div class="main-page">

        <!-- Start SideBar Menu -->
        <partial name="_AdminPartil" />
        <!-- End SideBar Menu -->
        <!-- Start Page Content -->
        <div class="content  ">

            <div class="content-container  m-0 p-5">
                <h3>تعديل عنصر</h3>
                <form method="post" asp-action="SaveUpdate" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="UserId" />

                    <div class="row w-100">
                        <div class="input col-lg-12">
                            <h5>الإسم:</h5>
                            <input asp-for="Email" id="Email" type="text" readonly />
                            <span asp-validation-for="Email" class="text-danger"></span>

                        </div>

                         <div class="input col-lg-12">
                            <h5>اختر المنطقة:</h5>
                            <select asp-for="RegionId" class="form-select form-select-lg mb-3 " asp-items="@ViewBag.Regions" required>
                            </select>
                        </div> 
                    </div>

                  
                    <input type="submit" value="إضافة" />
                </form>

            </div>
        </div>
        <!-- End Page Content -->
    </div>

    <style>
        .tox .tox-toolbar-overlord {
            background-color: var(--background-color);
            color: var(--text-color);
        }

        .tox .tox-edit-area__iframe {
            background-color: var(--background-color);
            color: var(--text-color);
        }
    </style>

    @section Sheets {
        <!-- DataTable CDN CSS -->
        <link rel="stylesheet" href="~/Css/bootstrap_452.min.css" />
        <link rel="stylesheet" href="~/Css/dataTables_bootstrap4.min.css" />

        <link rel="stylesheet" href="~/Css/all.min.css" />
        <!-- Global Style Page -->
        <link rel="stylesheet" href="~/Css/global.css" />


        <!-- Main Style Page -->
        <link rel="stylesheet" href="~/Css/home.css" />
        <!-- Main Style Page -->

        <link rel="stylesheet" href="~/Css/adminGlobal.css" />

        <link rel="stylesheet" href="~/Css/editInfoAdmin.css" />


    }

    @section Scripts {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/tinymce/6.8.2/tinymce.min.js"
                referrerpolicy="origin"></script>
        <!-- Alert Js File -->
        <script src="~/Js/addInfoAdminPanel.js"></script>

        <!-- Global Admin Js File -->
        <script src="~/JS/adminGlobal.js"></script>
    }

</main>
